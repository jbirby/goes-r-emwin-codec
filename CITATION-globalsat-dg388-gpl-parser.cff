    given-names: "J."
    alias: "jbirby"
repository-code: "https://github.com/jbirby/globalsat-dg388-gpl-parser"
url: "https://github.com/jbirby/globalsat-dg388-gpl-parser"
license: MIT
keywords:
  - gps
  - gps-data-logger
  - globalsat
  - dg-388
  - gpl
  - reverse-engineering
  - gpx
  - python
date-released: 2026-03-30
